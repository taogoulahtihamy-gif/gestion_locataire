<%@ page contentType="text/html;charset=UTF-8" import="java.util.*,com.location.entity.Utilisateur" %><!DOCTYPE html><html><head><title>Utilisateurs</title></head><body><%@ include file="/WEB-INF/views/fragments/header.jspf" %><div class="container"><h1>Gestion des utilisateurs</h1><% Utilisateur item=(Utilisateur)request.getAttribute("item"); %><form method="post" action="${pageContext.request.contextPath}/users"><input type="hidden" name="id" value="<%= item!=null?item.getId():"" %>"><div class="row"><div><label>Nom</label><input name="nom" value="<%= item!=null&&item.getNom()!=null?item.getNom():"" %>" required></div><div><label>Email</label><input type="email" name="email" value="<%= item!=null&&item.getEmail()!=null?item.getEmail():"" %>" required></div></div><div class="row"><div><label>Mot de passe</label><input type="password" name="motDePasse"></div><div><label>Rôle</label><select name="role"><option>ADMIN</option><option>PROPRIETAIRE</option><option>AGENT</option></select></div></div><label><input type="checkbox" name="actif" <%= item==null||item.isActif()?"checked":"" %>> Actif</label><br><button class="btn" type="submit">Enregistrer</button></form><table><tr><th>ID</th><th>Nom</th><th>Email</th><th>Rôle</th><th>Actif</th><th>Actions</th></tr><% for(Utilisateur u:(List<Utilisateur>)request.getAttribute("items")){ %><tr><td><%= u.getId() %></td><td><%= u.getNom() %></td><td><%= u.getEmail() %></td><td><%= u.getRole() %></td><td><%= u.isActif() ? "Oui":"Non" %></td><td><a class="btn btn-secondary" href="${pageContext.request.contextPath}/users?action=edit&id=<%= u.getId() %>">Modifier</a> <a class="btn btn-danger" href="${pageContext.request.contextPath}/users?action=delete&id=<%= u.getId() %>" onclick="return confirm('Supprimer ?')">Supprimer</a></td></tr><% } %></table></div></body></html>
